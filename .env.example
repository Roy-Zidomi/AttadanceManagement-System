DATABASE_URL="postgresql://username:password@localhost:5432/attendance_db?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-random-secret"

# Cloudinary (required for /api/upload)
CLOUDINARY_CLOUD_NAME=xxxx
CLOUDINARY_API_KEY=xxxx
CLOUDINARY_API_SECRET=xxxx
CLOUDINARY_UPLOAD_FOLDER=attendance-proofs

# Optional: override seed passwords (prisma/seed.ts)
SEED_ADMIN_PASSWORD=admin123
SEED_EMPLOYEE_PASSWORD=password123

# Initial admin bootstrap (run: npm run create-admin)
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=change-me-please
ADMIN_EMPLOYEE_ID=ADM-001
ADMIN_NAME=Super Admin
ADMIN_DEPARTMENT=Management

# Email OTP (Forgot Password)
# Production: configure Resend (free tier available)
RESEND_API_KEY=xxxx
EMAIL_FROM="ShiftTrack <onboarding@resend.dev>"

# Optional (recommended): separate secret for OTP hashing (falls back to NEXTAUTH_SECRET)
OTP_SECRET="replace-with-random-secret"
